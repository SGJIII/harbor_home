{
  "name": "family-room-booking",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "vite",
    "dev:netlify": "netlify dev",
    "build": "tsc -b && vite build",
    "build:netlify": "npm run build && npm run db:migrate",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc -b",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "deploy": "netlify deploy --prod"
  },
  "dependencies": {
    "@neondatabase/serverless": "latest",
    "@netlify/blobs": "latest",
    "@netlify/functions": "latest",
    "cheerio": "latest",
    "drizzle-orm": "0.45.2",
    "lucide-react": "latest",
    "nodemailer": "latest",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-router-dom": "latest",
    "sharp": "^0.34.5",
    "zod": "latest"
  },
  "devDependencies": {
    "@types/node": "22.19.19",
    "@types/nodemailer": "latest",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "drizzle-kit": "0.31.10",
    "netlify-cli": "latest",
    "typescript": "5.9.3",
    "vite": "8.1.4",
    "vitest": "latest"
  },
  "overrides": {
    "undici": "7.28.0",
    "@opentelemetry/core": "2.9.0",
    "@opentelemetry/resources": "2.9.0",
    "@opentelemetry/sdk-trace-base": "2.9.0",
    "@opentelemetry/sdk-trace-node": "2.9.0",
    "esbuild": "0.28.1"
  },
  "type": "module"
}
