# Browser-visible Neon Auth endpoint from Neon Console → Auth → Configuration.
VITE_NEON_AUTH_URL=

# Set true only for local/demo previews. Production must be false.
VITE_DEMO_MODE=true
ALLOW_DEMO_AUTH=false

# Server-only values configured in Netlify environment variables.
DATABASE_URL=
NEON_AUTH_BASE_URL=
ADMIN_EMAILS=
GMAIL_USER=
GMAIL_APP_PASSWORD=
