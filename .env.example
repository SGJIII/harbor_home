# Set true only for local/demo previews. Netlify production should be false.
VITE_DEMO_MODE=true

# Server-only values configured in Netlify environment variables.
DATABASE_URL=
# Generate with: openssl rand -hex 32
AUTH_SECRET=
# Exact host emails, comma-separated. They become active admins at first sign-in.
ADMIN_EMAILS=
# Gmail account used to deliver sign-in codes and booking notifications.
GMAIL_USER=
GMAIL_APP_PASSWORD=
