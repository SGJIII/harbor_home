{
  "compilerOptions": {
    "composite": true,
    "skipLibCheck": true,
    "module": "ESNext",
    "target": "ES2022",
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "types": ["node"]
  },
  "include": ["vite.config.ts", "netlify/**/*.ts", "netlify/**/*.mts", "db/**/*.ts", "drizzle.config.ts", "tests/**/*.ts", "src/data/personalPhotos.ts", "src/data/propertyPhotos.ts", "src/lib/bookingRules.ts", "src/lib/hostSchedule.ts", "src/types.ts"]
}
